homeassistant:
  url: "http://homeassistant.local:8123"
  token: "YOUR_LONG_LIVED_ACCESS_TOKEN"
  default_agent_id: ""
  default_language: "en"

whatsapp:
  bot_phone: "1234567890"
  qr_method: "terminal"  # "terminal" or "file"

users:
  "1234567890":
    name: "Alice"
    agent_id: "conversation.alice_assistant"
    language: "en"
  "0987654321":
    name: "Bob"
    agent_id: "conversation.bob_assistant"
    language: "de"

security:
  ignore_non_whitelisted: true

messages:
  command_prefix: ""
  health_check_command: "!ping"
  no_intent_reply: "Sorry, I didn't understand that. Try rephrasing your request."
  error_reply: "Home Assistant is currently unavailable. Please try again later."

logging:
  level: "INFO"
